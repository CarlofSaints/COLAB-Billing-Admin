# --- Database (Neon Postgres) ---
# Get this from Vercel > Storage > Neon, or from neon.tech. Use the pooled connection string.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# --- Auth ---
# A long random string used to sign session cookies. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
AUTH_SECRET="change-me-to-a-long-random-string"

# --- Email (Resend) --- add these in Vercel once ready
RESEND_API_KEY=""
# The verified "from" address on your domain, e.g. "COLAB <no-reply@colab2.co.za>"
MAIL_FROM="COLAB <no-reply@colab2.co.za>"

# --- Seeding ---
# Temporary password set for the initial Super Admin (carl@outerjoin.co.za) when running db:seed.
SEED_SUPERADMIN_PASSWORD="ChangeMe!2026"
